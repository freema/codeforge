FROM golang:1.24-alpine

RUN apk add --no-cache git nodejs npm ca-certificates tzdata curl coreutils gosu

# Install air for hot reload (pinned — latest requires Go 1.25+)
RUN go install github.com/air-verse/air@v1.61.7

# Install golangci-lint v2 (matches .golangci.yml version: "2")
RUN curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s -- -b /usr/local/bin v2.11.3

# Install Claude Code CLI (optional for dev — not needed for unit tests)
ARG CLAUDE_CODE_VERSION=1.0.88
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} 2>/dev/null || true

# Install OpenAI Codex CLI (optional for dev)
ARG CODEX_VERSION=0.104.0
RUN npm install -g @openai/codex@${CODEX_VERSION} 2>/dev/null || true

# Non-root user — Claude Code refuses bypassPermissions under root
RUN adduser -D -h /home/codeforge codeforge \
    && mkdir -p /data/workspaces \
    && chown -R codeforge:codeforge /data

# Allow git to work in directories owned by other users (root runs executor,
# codeforge user owns workspaces — git refuses to operate without this).
RUN git config --global --add safe.directory '*'

WORKDIR /app

EXPOSE 8080
CMD ["air", "-c", ".air.toml"]
